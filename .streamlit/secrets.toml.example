# Copy this into Streamlit Community Cloud → your app → Settings → Secrets.
# Do NOT commit a real secrets.toml. (.streamlit/secrets.toml is gitignored.)

DATA_SOURCE = "massive"              # default source; user can still toggle in-app

# --- Massive (formerly Polygon.io, default) — pure data vendor, email/password signup, no KYC ---
# Whole U.S. market in the $2-20 band, but End-of-Day only (refreshes once per trading day).
MASSIVE_API_KEY = ""

# --- Finnhub — pure data vendor, email/password signup only, no KYC ---
# Live/intraday, but a curated ~20-symbol list (no whole-market call on the free tier).
FINNHUB_API_KEY = ""
# FINNHUB_UNIVERSE = "F,SOFI,PLUG,NIO,SNAP"   # optional: override the default symbol list

# --- Schwab (optional, user-toggled) — OAuth 2.0, Paul's own account, never a password ---
SCHWAB_APP_KEY = ""
SCHWAB_APP_SECRET = ""
SCHWAB_REDIRECT_URI = "https://mp-trading-terminal.streamlit.app"
# SCHWAB_UNIVERSE = "F,SOFI,PLUG,NIO,SNAP"    # optional: override the default symbol list

ENABLE_ORDER_ENTRY = "false"         # keep false unless live trading is explicitly wanted
SCAN_REFRESH_SECONDS = "60"
