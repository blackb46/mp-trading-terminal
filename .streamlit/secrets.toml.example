# Copy this into Streamlit Community Cloud → your app → Settings → Secrets.
# Do NOT commit a real secrets.toml. (.streamlit/secrets.toml is gitignored.)
#
# Schwab uses OAuth 2.0 — App Key/Secret only, never a username/password.

DATA_SOURCE = "mock"                 # switch to "schwab" once the app is approved

SCHWAB_APP_KEY = ""
SCHWAB_APP_SECRET = ""
SCHWAB_REDIRECT_URI = "https://mp-trading-terminal.streamlit.app"

ENABLE_ORDER_ENTRY = "false"         # keep false unless live trading is explicitly wanted
SCAN_REFRESH_SECONDS = "60"
